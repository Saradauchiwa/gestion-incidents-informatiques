# Copier ce fichier vers .env puis renseigner vos propres valeurs
# Ne jamais committer le fichier .env final sur GitHub

# --- Utilisé en exécution locale (sans Docker) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gestion_des_incidents_informatiques
DB_USER=app_login
DB_PASSWORD=change_moi

FLASK_SECRET_KEY=change_moi_par_une_valeur_aleatoire_longue

# --- Utilisé uniquement par docker-compose ---
# Mot de passe du superutilisateur postgres à l'intérieur du conteneur
POSTGRES_PASSWORD=change_moi_aussi
